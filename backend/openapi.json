        "type": "string",
        "enum": [
          "lesson_completed",
          "quiz_attempted",
          "note_added"
        ],
        "title": "ActivityType"
      },
      "GroupStats": {
        "properties": {
          "group_id": {
            "type": "integer",
            "title": "Group Id"
          },
          "total_activities": {
            "type": "integer",
            "title": "Total Activities"
          },
          "average_quiz_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Average Quiz Score"
          }
        },
        "type": "object",
        "required": [
          "group_id",
          "total_activities"
        ],
        "title": "GroupStats"
