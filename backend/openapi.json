            "$ref": "#/components/schemas/ActivityType"
          },
          "score": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "last_changed": {
            "type": "string",
            "format": "date",
            "title": "Last Changed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "student_id",
          "activity_type",
          "last_changed",
          "created_at"
        ],
        "title": "Activity"
      },
      "ActivityCreate": {
        "properties": {
          "activity_type": {
            "$ref": "#/components/schemas/ActivityType"
          },
          "score": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "last_changed": {
            "type": "string",
            "format": "date",
            "title": "Last Changed"
          }
